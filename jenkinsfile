pipeline {
    agent any

    environment {
        strDockerImage = "seungwankim364/cicd-test:0.1"
    }

    stages {
        stage('Github Pull') {
            steps {
                git branch: 'main', url: 'https://github.com/seungwankim364/cicd-test.git'
            }
        }

        stage('Docker Image Build') {
            steps {
                script {
                    oDockImage = docker.build(strDockerImage, "-f Dockerfile .")
                }
            }
        }
        stage('Docker Image Push') {
            steps {
                script {
                    docker.withRegistry('', 'docker-auth') {
                        oDockImage.push()
                    }
                }
            }
        }   
        
        stage('Deploy Server') {
            steps {
                sshagent(credentials: ['Deploy-Private-Key']) {
                    sh "scp -o StrictHostKeyChecking=no index.html ubuntu@43.202.55.59:/home/ubuntu"
                    sh "ssh -o StrictHostKeyChecking=no ubuntu@43.202.55.59 sudo cp /home/ubuntu/index.html /var/www/html/"
                }
            }
        }
    }
}