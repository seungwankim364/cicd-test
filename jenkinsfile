import java.text.SimpleDateFormat

def TODAY = (new SimpleDateFormat("yyyy-MM-dd")).format(new Date())

pipeline {
    agent any

    environment {
        strDockerTag = "${TODAY}_${BUILD_ID}"
        strDockerImage = "seungwankim364/cicd-test:${strDockerTag}"
    }

    stages {
        stage('Github Pull') {
            steps {
                git branch: 'main', url: 'https://github.com/seungwankim364/cicd-test.git'
            }
        }

        stage('Docker Image Build') {
            steps {
                script {
                    oDockImage = docker.build(strDockerImage, "-f Dockerfile .")
                }
            }
        }
        stage('Docker Image Push') {
            steps {
                script {
                    docker.withRegistry('', 'docker-auth') {
                        oDockImage.push()
                    }
                }
            }
        }   
        
        stage('Deploy Server') {
            steps {
                sshagent(credentials: ['Deploy-Private-Key']) {
                    sh "scp -o StrictHostKeyChecking=no ubuntu@43.202.55.59 docker container rm -f sampleweb"
                    sh "ssh -o StrictHostKeyChecking=no ubuntu@43.202.55.59 docker run -d -p 80:80 --name sampleweb ${strDockerImage}"
                }
            }
        }
    }
}